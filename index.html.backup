<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Rắn Tri Thức: Cuộc Đua Phân Loại</title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 100 100%22><text y=%22.9em%22 font-size=%2290%22>🐍</text></svg>">
    <link rel="stylesheet" href="css/style.css">
</head>
<body>
    <!-- Màn hình Welcome -->
    <div id="welcomeScreen" class="screen">
        <div class="welcome-container">
            <div class="welcome-content">
                <h1 class="welcome-title">🐍 Rắn Tri Thức 🐍</h1>
                <p class="welcome-subtitle">Cuộc Đua Phân Loại</p>
                <div class="welcome-description">
                    <p>🎮 Đối đầu với AI thông minh</p>
                    <p>🍎 Ăn đúng thức ăn để ghi điểm</p>
                    <p>📚 Trả lời câu hỏi để tăng trưởng</p>
                    <p>💣 Tránh bom để không bị choáng</p>
                </div>
                <button id="letsGoBtn" class="btn-lets-go">Let's Go! 🚀</button>
            </div>
        </div>
    </div>
    
    <!-- Màn hình chọn cấp độ -->
    <div id="menuScreen" class="screen" style="display: none;"></div>
        <div class="menu-container">
            <h1 class="game-title">🐍 Rắn Tri Thức</h1>
            
            <div class="menu-content">
                <p class="game-description">
                    Đối đầu với AI thông minh! Ăn đúng thức ăn theo chủ đề, tránh bẫy sai để ghi điểm.
                </p>
                
                <!-- Bước 1: Chọn đối thủ -->
                <div id="step1" class="step-container active">
                    <div class="difficulty-selection">
                        <h3>Bước 1: Chọn đối thủ</h3>
                        
                        <div class="difficulty-cards">
                            <div class="difficulty-card" data-level="easy">
                                <div class="difficulty-icon">😊🌱🐢</div>
                                <div class="difficulty-name">🐍 Rắn AI<br>Mới Vào Nghề</div>
                            </div>
                            
                            <div class="difficulty-card active" data-level="medium">
                                <div class="difficulty-icon">😐⚡🎯</div>
                                <div class="difficulty-name">🐍 Rắn AI<br>Chuyên Nghiệp</div>
                            </div>
                            
                            <div class="difficulty-card" data-level="hard">
                                <div class="difficulty-icon">😈🔥💀</div>
                                <div class="difficulty-name">🐍 Rắn AI<br>Huyền Thoại</div>
                            </div>
                        </div>
                    </div>
                    <button id="nextBtn1" class="btn-next">Tiếp theo →</button>
                </div>
                
                <!-- Bước 2: Chọn chế độ chơi -->
                <div id="step2" class="step-container">
                    <div class="game-mode-selection">
                        <h3>Bước 2: Chế độ chơi</h3>
                        <div class="mode-buttons">
                            <button class="mode-btn active" data-mode="single">
                                <span class="mode-icon">🤖</span>
                                <span class="mode-name">1 Người vs AI</span>
                            </button>
                            <button class="mode-btn" data-mode="multi">
                                <span class="mode-icon">👥</span>
                                <span class="mode-name">2 Người vs AI</span>
                            </button>
                        </div>
                    </div>
                    <div class="step-buttons space-between">
                        <button id="backBtn1" class="btn-back-step">← Quay lại</button>
                        <button id="nextBtn2" class="btn-next">Tiếp theo →</button>
                    </div>
                </div>
                
                <!-- Bước 3: Chọn tốc độ và thời gian -->
                <div id="step3" class="step-container">
                    <h3>Bước 3: Cài đặt game</h3>
                    
                    <div class="speed-setting">
                        <label for="gameSpeed">⚡ Tốc độ game:</label>
                        <div class="speed-slider-container">
                            <span class="speed-label">Chậm</span>
                            <input type="range" id="gameSpeed" min="1" max="5" value="3" step="1">
                            <span class="speed-label">Nhanh</span>
                        </div>
                        <div class="speed-value">Tốc độ: <span id="speedDisplay">Trung bình</span></div>
                    </div>
                    
                    <div class="time-setting">
                        <label for="gameTime">⏱️ Thời gian chơi (giây):</label>
                        <input type="number" id="gameTime" min="30" max="300" value="30" step="10">
                    </div>
                    
                    <div class="step-buttons space-between">
                        <button id="backBtn2" class="btn-back-step">← Quay lại</button>
                        <button id="playBtn" class="btn-play">Bắt đầu chơi 🎮</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Màn hình chơi game -->
    <div id="gameScreen" class="screen" style="display: none;">
        <div class="game-container">
            <div class="game-info">
                <div class="player-info-combined player-blue-green">
                    <div class="player-section">
                        <div class="player-name">👤 Người chơi 1 (↑↓←→)</div>
                        <div class="length">Độ dài: <span id="player-length">3</span></div>
                        <div id="player-status" class="status"></div>
                    </div>
                    
                    <div id="player3-section" class="player-section player-divider" style="display: none;">
                        <div class="player-name">👤 Người chơi 2 (WASD)</div>
                        <div class="length">Độ dài: <span id="player3-length">3</span></div>
                        <div id="player3-status" class="status"></div>
                    </div>
                </div>
                
                <div class="timer-panel">
                    <div class="timer-label">⏱️ Thời gian</div>
                    <div id="timer" class="timer">60</div>
                </div>
                
                <div class="player-info player-red">
                    <div class="player-name" id="player2-name">🤖 AI</div>
                    <div class="length">Độ dài: <span id="ai-length">3</span></div>
                    <div id="ai-status" class="status"></div>
                </div>
            </div>
            
            <div class="controls">
                <button id="pauseBtn" class="btn-pause">Tạm dừng</button>
                <div class="control-hint">
                    <span id="control-text">⌨️ Điều khiển: Phím mũi tên ← ↑ → ↓</span>
                </div>
                <button id="backBtn" class="btn-back">Về menu</button>
            </div>
            
            <canvas id="gameCanvas"></canvas>
            
            <div class="legend">
                <div class="legend-item">
                    <span class="legend-color" style="background: #4CAF50;"></span>
                    <span>Trái cây (+1 đốt) | ⭐ Trái cây bự (+3 đốt, mỗi 5s)</span>
                </div>
                <div class="legend-item">
                    <span class="legend-color" style="background: #f44336;"></span>
                    <span>Bom (-2 đốt, choáng 2s)</span>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Modal kết thúc game -->
    <div id="gameOverModal" class="modal">
        <div class="modal-content">
            <h2 id="gameOverTitle"></h2>
            <div id="gameOverStats"></div>
            <button id="restartBtn" class="btn-restart">Chơi lại</button>
            <button id="menuBtn" class="btn-menu">Về menu</button>
        </div>
    </div>
    
    <!-- Modal câu hỏi -->
    <div id="questionModal" class="modal">
        <div class="modal-content question-modal">
            <h2 id="questionTitle">📚 Câu hỏi</h2>
            <div id="questionTimer" class="question-timer">10</div>
            <p id="questionText" class="question-text"></p>
            <div id="questionAnswers" class="question-answers"></div>
        </div>
    </div>
    
    <!-- Load JavaScript files theo thứ tự -->
    <script src="js/config.js"></script>
    <script src="js/constants.js"></script>
    <script src="js/utils.js"></script>
    <script src="js/audio-manager.js"></script>
    <script src="js/snake-manager.js"></script>
    <script src="js/food-manager.js"></script>
    <script src="js/question-manager.js"></script>
    <script src="js/ui-manager.js"></script>
    <script src="js/collision-manager.js"></script>
    <script src="js/input-controller.js"></script>
    <script src="js/ai-controller.js"></script>
    <script src="js/renderer.js"></script>
    <script src="js/game.js"></script>
</body>
</html>
